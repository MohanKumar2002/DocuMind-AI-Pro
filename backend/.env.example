# ── AI ENGINE ──
GROQ_API_KEY=your_groq_api_key_here
# Get free at: https://console.groq.com
# Free tier: 14,400 requests/day, Llama 3.1 70B

# ── SUPABASE ──
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# Get free at: https://supabase.com

# ── RAZORPAY ──
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Get free at: https://razorpay.com

# ── JWT ──
JWT_SECRET=your_super_secret_key_change_this_in_production_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── APP ──
APP_NAME=DocuMind AI
APP_VERSION=3.0.0
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ── STORAGE ──
UPLOAD_DIR=./uploads
CHROMA_DIR=./chromadb
MAX_FILE_SIZE_MB=50

# ── HUGGINGFACE ──
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Free, downloads once (~90MB), runs locally
